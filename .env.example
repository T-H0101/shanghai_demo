# API Mode Configuration
# 可选值: api, mock
NEXT_PUBLIC_API_MODE=api

# api 模式:
# - 页面通过 /api/* 端点获取中心库与外部服务数据
# - API 请求失败必须显式显示错误/待接入状态, 不允许静默回退到 mock
# - 本项目默认使用 api 模式, 用于真实联调和验收
#
# mock 模式:
# - 仅限隔离前端样式调试, 不可作为 requirements 完成证据
# - 开启前必须在当前 Sprint review 中明确标注 UI-only

# ============================================================
# PostgreSQL 数据库配置 (Sprint 2B)
# ============================================================
# Docker Compose 本地开发环境（默认）
DATABASE_URL=postgresql://unified:unified123@localhost:5432/unified_disc_platform

# 独立密码字段 (Sprint 4.8.1.7) - e2e 脚本直读
# 必须与 DATABASE_URL 里的密码一致
DB_PASSWORD=unified123

# 可选：连接池配置
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT_MS=30000

# 注意：
# - .env.local 不要提交（包含真实密码）
# - 使用 docker-compose.yml 启动本地 PostgreSQL 17

# ============================================================
# Ingest API Keys
# 格式：INGEST_API_KEY_{siteCode}=your-secret-key
# 注意：不要提交真实 key 到 git
# ============================================================
INGEST_API_KEY_SH01=replace-with-site-api-key

# ============================================================
# Source Restore 数据库配置 (Sprint 2B.12)
# 用于真实数据导入，连接 source_restore 数据库
# ============================================================
SOURCE_DATABASE_URL=postgresql://user:password@localhost:5432/source_restore

# ============================================================
# Sync Package HMAC 鉴权 (Sprint 2G.1)
# 保护 POST /api/sync/package 写入入口
# 详见 docs/summary/SYNC_TESTING_AND_AUTOMATION.md
# ============================================================
# strict = 必须 HMAC 签名 (生产)
# dev    = 允许无签名, 仅开发
SYNC_PACKAGE_AUTH_MODE=strict
# 生产必须配置, 至少 32 字符随机串
# 可用: openssl rand -hex 32
SYNC_PACKAGE_SECRET=replace-with-site-secret

# 导出签名配置边界: 仅保存密钥引用, 不保存私钥值
# 未配置时 /api/logs/export x-manifest.signature.status = blocked_by_config
EXPORT_SIGNING_KEY_REF=

# ============================================================
# Site Worker (Sprint 4.8.1)
# 真实控制链路. 部署到站点侧, 直连站点 PG (内部项目无 API)
# ============================================================
# 站点 worker 标识 (e.g. SH01)
SITE_WORKER_SITE_CODE=SH01

# true (默认) = dev 模式, 不真改站点 DB, 仅审计 + log
# false = 生产模式, 必须同时设 SITE_DATABASE_URL
SITE_WORKER_DRY_RUN=true

# 生产模式必填, dev 模式可省. 站点侧 PG 连接 (worker 部署到站点侧时)
# 必须由运维配, 与 DATABASE_URL 完全不同
SITE_DATABASE_URL=

# 拉取间隔 (ms), 默认 1000
SITE_WORKER_POLL_INTERVAL_MS=1000

# HA 模式: single (默认) / multi (SKIP LOCKED, 多 worker)
SITE_WORKER_HA_MODE=single

# Health check 端口
SITE_WORKER_HEALTH_PORT=3001

# ============================================================
# Standalone Site Agent control
# ============================================================
# 独立 Site Agent 控制轮询配置。总控新建/暂停/恢复等命令写入控制队列，
# 由站点 Agent 主动拉取并在站点库执行。
SITE_AGENT_CONTROL_POLL_INTERVAL_MS=5000
SITE_AGENT_CONTROL_LEASE_MS=30000
SITE_AGENT_CONTROL_BATCH_SIZE=20

# ============================================================
# Replaceable authentication configuration boundary
# ============================================================
# local / oidc / ldap. 当前已实现中心平台 local JWT/RBAC 基座; oidc/ldap 需企业 IdP 配置后接入。
AUTH_MODE=local
AUTH_SESSION_SECRET=replace-with-32-byte-random-session-secret
AUTH_SESSION_TTL_SECONDS=7200
AUTH_ISSUER_URL=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_CLIENT_SECRET_REF=AUTH_CLIENT_SECRET
AUTH_JWKS_URL=
AUTH_LDAP_URL=
AUTH_LDAP_BASE_DN=

# ============================================================
# Admin Token (Sprint 4.7)
# 保护 /api/sync/devices + /api/sync/tasks 内部 trigger 端点
# strict 模式必填, 至少 24 字符
# ============================================================
# 可用: openssl rand -hex 24
ADMIN_TOKEN=replace-with-admin-token

# ============================================================
# 真实生产示例 (Sprint 4.8.1.8)
# 内部项目: 部署 worker 到站点侧, 站点表 schema 由站点运维维护
# 总控不修改站点表结构, 仅通过 control_command 表达"已下发"
# ============================================================
# SITE_DATABASE_URL=postgresql://site_user:replace-with-real-password@site-host:5432/site_db
# SITE_WORKER_DRY_RUN=false

# ============================================================
# R.56: ES / OpenSearch (env-only, no secrets in git)
# ============================================================
SEARCH_ES_URL=http://localhost:9200
SEARCH_ES_INDEX=disc_file_index
SEARCH_ES_USERNAME=
SEARCH_ES_PASSWORD_KEY_REF=SEARCH_ES_PASSWORD

# ============================================================
# R.57: ClickHouse (env-only, password via key ref)
# ============================================================
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=unified_logs
CLICKHOUSE_LOG_TABLE=task_logs_dev
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD_KEY_REF=CLICKHOUSE_PASSWORD

# ============================================================
# R.59/R.65: OIDC / LDAP enterprise auth (boundary only)
# ============================================================
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET_KEY_REF=OIDC_CLIENT_SECRET
OIDC_JWKS_URL=
LDAP_URL=
LDAP_BASE_DN=
LDAP_BIND_DN_KEY_REF=LDAP_BIND_DN
LDAP_BIND_PASSWORD_KEY_REF=LDAP_BIND_PASSWORD
