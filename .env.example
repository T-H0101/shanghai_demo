# API Mode Configuration
# 可选值: mock (默认), api
NEXT_PUBLIC_API_MODE=mock

# mock 模式:
# - 页面使用 lib/mock/* 中的 Mock 数据
# - 不发起 API 请求
# - 适合前端开发和演示

# api 模式:
# - 页面通过 /api/* 端点获取数据
# - API 请求失败时自动 fallback 到 mock
# - 适合与后端服务联调

# ============================================================
# PostgreSQL 数据库配置 (Sprint 2B)
# ============================================================
# Docker Compose 本地开发环境（默认）
DATABASE_URL=postgresql://unified:password@localhost:5432/unified_disc_platform

# 可选：连接池配置
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# DB_IDLE_TIMEOUT_MS=30000

# 注意：
# - .env.local 不要提交（包含真实密码）
# - 使用 docker-compose.yml 启动本地 PostgreSQL 17
